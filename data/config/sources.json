{
  "_comment": "Observer source registry. Each entry defines one data source, its endpoint, fallbacks, rate limits, and label conventions. Observers poll these, write to data/sources/*.json, and never directly modify js/data.js.",

  "commodity_prices": {
    "label": "Commodity Prices",
    "observer": "observers/fetch_commodity_prices.py",
    "output": "data/sources/commodity-prices.json",
    "primary": {
      "provider": "oilpriceapi",
      "endpoint": "https://api.oilpriceapi.com/v1/prices/all",
      "auth_header": "Authorization",
      "auth_env": "OILPRICE_API_KEY",
      "api_key_fallback": "f719bf8a7ff3844d0a5436da144bc985db3acf2431ddf3095702b1c5f4926e5a",
      "rate_limit_per_day": 333,
      "_rate_note": "10,000 requests/month free tier"
    },
    "fallback": {
      "provider": "static",
      "_note": "If API fails, keep the last-good snapshot rather than zero-out values."
    },
    "refresh_cadence_minutes": 15,
    "label_fresh": "Live",
    "label_stale": "Delayed",
    "stale_threshold_minutes": 60,
    "failed_threshold_minutes": 180,
    "schema": {
      "generated_at": "ISO 8601 UTC",
      "prices": {
        "WTI Crude":    { "price": "float", "change": "float", "pct": "float", "unit": "$/bbl", "source_code": "WTI_USD" },
        "Brent Crude":  { "price": "float", "change": "float", "pct": "float", "unit": "$/bbl", "source_code": "BRENT_CRUDE_USD" }
      }
    }
  },

  "gas_prices_aaa": {
    "label": "AAA National Gas Prices",
    "observer": "observers/fetch_gas_prices.py",
    "output": "data/sources/gas-prices-national.json",
    "primary": {
      "provider": "aaa",
      "endpoint": "https://gasprices.aaa.com/",
      "_note": "Currently blocked by GitHub Actions IP (403). Falls back to EIA."
    },
    "fallback": {
      "provider": "eia",
      "endpoint": "https://api.eia.gov/v2/petroleum/pri/gnd/data/",
      "_note": "EIA weekly average — less daily but reliable.",
      "api_key_env": "EIA_API_KEY"
    },
    "refresh_cadence_hours": 24,
    "label_fresh": "AAA Daily",
    "label_stale": "EIA Weekly",
    "stale_threshold_hours": 30,
    "failed_threshold_hours": 72
  },

  "gas_prices_by_state": {
    "label": "U.S. Gas Prices by State",
    "observer": "observers/fetch_gas_prices_by_state.py",
    "output": "data/sources/gas-prices-by-state.json",
    "primary": {
      "provider": "aaa",
      "endpoint": "https://gasprices.aaa.com/state-gas-price-averages/",
      "_note": "51 states + D.C. scraped from AAA table."
    },
    "fallback": {
      "provider": "eia",
      "_note": "EIA PADD-level + manual static if EIA unavailable."
    },
    "refresh_cadence_hours": 24,
    "stale_threshold_hours": 48,
    "failed_threshold_hours": 96
  }
}
